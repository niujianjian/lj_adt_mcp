# SAP System Connection
# Hostname of your SAP system (without protocol or port)
SAP_HOSTNAME=your-sap-host.example.com

# SAP System Number (used to calculate HTTPS port: 443 + sysnr → e.g., 50 → port 44350)
SAP_SYSNR=00

# SAP credentials
SAP_USERNAME=YOUR_USER
SAP_PASSWORD=YOUR_PASSWORD

# SAP Client
SAP_CLIENT=001

# SAP Logon Language (default: EN)
SAP_LANGUAGE=EN
